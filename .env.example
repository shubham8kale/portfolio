# Server-side only — set these in Vercel project settings (and .env.local for dev).
# NEVER prefix any of these with NEXT_PUBLIC_.

# Groq API key (console.groq.com). Without it /api/chat returns a friendly 503.
GROQ_API_KEY=

# Optional model override; defaults to llama-3.3-70b-versatile.
# Check console.groq.com/docs/models for the current catalog.
GROQ_MODEL=

# Upstash Redis (console.upstash.com, free tier) — rate limiting.
# Without these the bot still works but is unlimited (Groq quota is the only bound).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public site URL used for metadata/sitemap (safe to expose).
NEXT_PUBLIC_SITE_URL=
